{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ArtifactBucketAccess",
            "Effect": "Allow",
            "Action": ["s3:GetObject", "s3:PutObject", "s3:ListBucket"],
            "Resource": ["arn:aws:s3:::devsecops-jenkins-artifacts-sun", "arn:aws:s3:::devsecops-jenkins-artifacts-sun/*"]
        },
        {
            "Sid": "IaCTestDeployPermissions",
            "Effect": "Allow",
            "Action": ["ec2:Describe*", "s3:ListAllMyBuckets"],
            "Resource": "*"
        }
    ]
}